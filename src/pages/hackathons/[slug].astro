---
import Layout from '@layouts/Default.astro';
import data from '@data/hackathons.json';

export async function getStaticPaths() {
  return data.hackathons.map(hackathon => ({
    params: { slug: hackathon.slug },
    props: { hackathon },
  }));
}

const { hackathon } = Astro.props;

const allHackathonContent = import.meta.glob('/src/data/hackathons/*.mdx', { eager: true });
const matchingPath = Object.keys(allHackathonContent).find(path => path.endsWith(`${hackathon.slug}.mdx`));

if (!matchingPath) {
  throw new Error(`Could not find MDX file for hackathon slug: ${hackathon.slug}`);
}

const { Content } = allHackathonContent[matchingPath];

// Auto-calculate status
const now = new Date();
const start = new Date(hackathon.startDate);
const end = new Date(hackathon.endDate);

let status = 'past';
if (now < start) status = 'upcoming';
else if (now >= start && now <= end) status = 'ongoing';

// Format Date Range
const options = { month: 'short', day: 'numeric' };
const startPart = start.toLocaleDateString('en-US', options);
const endPart = end.getDate();
const year = start.getFullYear();
const dateString = (start.getMonth() === end.getMonth()) 
    ? `${startPart} - ${endPart}, ${year}`
    : `${startPart} - ${end.toLocaleDateString('en-US', options)}, ${year}`;
---

<Layout title={hackathon.title}>
  <section class="hero is-medium is-link" style={`background-image: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('${hackathon.banner}'); background-size: cover; background-position: center;`}>
    <div class="hero-body">
      <div class="container has-text-centered">
        <h1 class="title is-1">{hackathon.title}</h1>
        <h2 class="subtitle is-3">{dateString}</h2>
        
        <div class="tags are-large is-centered mb-4">
            {status === 'upcoming' && <span class="tag is-success">Upcoming</span>}
            {status === 'ongoing' && <span class="tag is-info"><i class="fa-solid fa-bolt mr-2"></i>Happening Now</span>}
            {status === 'past' && <span class="tag is-dark">Past Event</span>}
        </div>

        <div class="tags are-medium is-centered">
            <span class="tag is-dark"><i class="fa-solid fa-location-dot mr-2"></i> {hackathon.location}</span>
            <span class="tag is-primary"><i class="fa-solid fa-ticket mr-2"></i> {hackathon.price}</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
        <div class="columns is-centered">
            <div class="column is-two-thirds">
                
                {/* Action Buttons Box - Shows if Devpost exists OR if event is upcoming */}
                {(status === 'upcoming' || hackathon.devpostLink) && (
                    <div class="notification is-light has-text-centered mb-6">
                        <h3 class="title is-4">Event Actions</h3>
                        <div class="buttons is-centered">
                            {/* Rubric Registration: ONLY if upcoming */}
                            {status === 'upcoming' && hackathon.rubricLink && (
                                <a href={hackathon.rubricLink} target="_blank" rel="noopener noreferrer" class="button is-warning is-medium">
                                    <strong>Register on Rubric</strong>
                                    <span class="icon ml-2"><i class="fa-solid fa-ticket"></i></span>
                                </a>
                            )}
                            
                            {/* Devpost Link: ALWAYS visible if link exists */}
                            {hackathon.devpostLink && (
                                <a href={hackathon.devpostLink} target="_blank" rel="noopener noreferrer" class="button is-link is-medium">
                                    <strong>View on Devpost</strong>
                                    <span class="icon ml-2"><i class="fa-solid fa-code"></i></span>
                                </a>
                            )}
                        </div>
                    </div>
                )}

                <div class="content is-medium">
                    <Content />
                </div>
            </div>
        </div>
    </div>
  </section>
</Layout>