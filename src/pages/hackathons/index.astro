---
import Layout from '@layouts/Default.astro'
import data from '@data/hackathons.json'

const hackathons = data.hackathons

// Helper: Determine Status
const getStatus = (startStr, endStr) => {
  const now = new Date();
  const start = new Date(startStr);
  const end = new Date(endStr);
  if (now < start) return 'upcoming';
  if (now >= start && now <= end) return 'ongoing';
  return 'past';
};

// Helper: Format Date Range (e.g., "Feb 13 - 14, 2026")
const formatDateRange = (startStr, endStr) => {
  const start = new Date(startStr);
  const end = new Date(endStr);
  
  const options = { month: 'short', day: 'numeric' };
  const startPart = start.toLocaleDateString('en-US', options);
  const endPart = end.getDate(); // Just the day number
  const year = start.getFullYear();

  // If same month: "Feb 13 - 14, 2026"
  if (start.getMonth() === end.getMonth()) {
    return `${startPart} - ${endPart}, ${year}`;
  }
  // If different months: "Jan 31 - Feb 2, 2026"
  return `${startPart} - ${end.toLocaleDateString('en-US', options)}, ${year}`;
};
---

<Layout title='UAIS Hackathons'>
  <section class="section">
    <div class="container">
      <h1 class="title has-text-centered">Hackathons</h1>
      <p class="subtitle has-text-centered mb-6">
        Join us to build, learn, and compete.
      </p>

      {hackathons.map(hackathon => {
        const status = getStatus(hackathon.startDate, hackathon.endDate);
        const dateString = formatDateRange(hackathon.startDate, hackathon.endDate);
        
        return (
          <div class="box">
            <article class="media">
              <figure class="media-left is-hidden-mobile">
                <p class="image is-128x128">
                  <img src={hackathon.banner} alt={`${hackathon.title} Banner`} style="object-fit: cover; border-radius: 6px;">
                </p>
              </figure>
              <div class="media-content">
                <div class="content">
                  <div class="level mb-2">
                      <div class="level-left">
                          <h2 class="title is-4">{hackathon.title}</h2>
                      </div>
                      <div class="level-right">
                          {status === 'upcoming' && <span class="tag is-success is-light">Upcoming</span>}
                          {status === 'ongoing' && <span class="tag is-info is-light"><span class="icon is-small mr-1"><i class="fa-solid fa-bolt"></i></span>Happening Now</span>}
                          {status === 'past' && <span class="tag is-dark is-light">Past</span>}
                      </div>
                  </div>
                  <p>
                      <span class="icon-text mr-4">
                          <span class="icon has-text-info"><i class="fa-solid fa-calendar"></i></span>
                          <span>{dateString}</span>
                      </span>
                      <span class="icon-text">
                          <span class="icon has-text-danger"><i class="fa-solid fa-location-dot"></i></span>
                          <span>{hackathon.location}</span>
                      </span>
                  </p>
                  <p>{hackathon.summary}</p>
                  
                  <div class="buttons">
                      <a href={`/hackathons/${hackathon.slug}`} class="button is-primary">
                        <span>Event Details</span>
                      </a>
                      
                      {/* Devpost: ALWAYS show if link exists */}
                      {hackathon.devpostLink && (
                          <a href={hackathon.devpostLink} class="button is-link is-outlined" target="_blank" rel="noopener noreferrer">
                              <span>Devpost</span>
                              <span class="icon is-small"><i class="fa-solid fa-code"></i></span>
                          </a>
                      )}

                      {/* Rubric: ONLY show if upcoming */}
                      {status === 'upcoming' && hackathon.rubricLink && (
                          <a href={hackathon.rubricLink} class="button is-warning" target="_blank" rel="noopener noreferrer">
                              <span>Register on Rubric</span>
                              <span class="icon is-small"><i class="fa-solid fa-external-link-alt"></i></span>
                          </a>
                      )}
                  </div>
                </div>
              </div>
            </article>
          </div>
        );
      })}

    </div>
  </section>
</Layout>