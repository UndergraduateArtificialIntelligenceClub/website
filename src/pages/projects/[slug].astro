---
import Layout from '@layouts/Default.astro';
import data from '@data/projects.json';

export async function getStaticPaths() {
  // Extract all years (keys) from the data object
  const years = Object.keys(data);
  // Flatten all projects from all years into a single array
  const allProjects = years.flatMap(year => data[year]);
  
  return allProjects.map(project => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;

const allProjectMdxFiles = import.meta.glob('/src/data/projects/*.mdx', { eager: true });
const matchingPath = Object.keys(allProjectMdxFiles)
  .find(path => path.endsWith(`${project.slug}.mdx`));

if (!matchingPath) {
  throw new Error(`Could not find MDX file for slug: ${project.slug}`);
}

const mdxModule = allProjectMdxFiles[matchingPath];
const { Content } = mdxModule;
---

<Layout title={`Project: ${project.title}`}>
  <section class="section">
    <div class="container content">
      <Content />

      {project.leads && project.leads.length > 0 && (
        <div class="box mt-6">
          <h3 class="title is-5">Project Lead{project.leads.length > 1 ? 's' : ''}</h3>
          {project.leads.map(lead => (
            <div class="mb-4">
              <p class="is-size-5 has-text-weight-semibold mb-2">{lead.name}</p>
              <div class="tags">
                {lead.email && <a href={`mailto:${lead.email}`} class="tag is-medium is-dark"><span class="icon mr-1"><i class="fa-solid fa-envelope"></i></span>Email</a>}
                {lead.discord && <span class="tag is-medium is-info"><span class="icon mr-1"><i class="fa-brands fa-discord"></i></span>{lead.discord}</span>}
                {lead.github && <a href={`https://github.com/${lead.github}`} class="tag is-medium is-black" target="_blank" rel="noopener noreferrer"><span class="icon mr-1"><i class="fa-brands fa-github"></i></span>GitHub</a>}
              </div>
            </div>
          ))}
        </div>
      )}

      {project.members && project.members.length > 0 && (
        <div class="box mt-5">
            <h3 class="title is-5">Team Members</h3>
            <ul class="tags are-medium">
                {project.members.map(member => (
                    <li class="tag is-light">{member.name}</li>
                ))}
            </ul>
        </div>
      )}

    </div>
  </section>
</Layout>